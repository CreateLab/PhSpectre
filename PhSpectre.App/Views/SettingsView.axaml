<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PhSpectre.App.ViewModels"
        x:Class="PhSpectre.App.Views.SettingsView"
        x:DataType="vm:SettingsViewModel"
        Width="450" Height="730"
        Title="Settings"
        CanResize="True"
        WindowStartupLocation="CenterOwner">

    <ScrollViewer Padding="24,18,24,18" VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="6">

            <!-- ── Palette ───────────────────────────────────────────── -->
            <TextBlock Text="PALETTE"
                       FontSize="10" FontWeight="SemiBold"
                       Opacity="0.4" LetterSpacing="1.5"
                       Margin="2,0,0,4"/>

            <Border BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6" Padding="12,10">
                <StackPanel Spacing="10">

                    <Grid ColumnDefinitions="110,*">
                        <TextBlock Text="Sampling" VerticalAlignment="Center" Opacity="0.75"/>
                        <ComboBox Grid.Column="1" x:Name="SamplingModeBox"
                                  SelectedIndex="{Binding SamplingModeIndex}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>

                    <Grid ColumnDefinitions="110,*">
                        <TextBlock Text="Colors" VerticalAlignment="Center" Opacity="0.75"/>
                        <ComboBox Grid.Column="1" x:Name="ColorCountBox"
                                  SelectedIndex="{Binding ColorCountIndex}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>

                    <Grid ColumnDefinitions="110,*">
                        <TextBlock Text="Theme" VerticalAlignment="Center" Opacity="0.75"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                            <RadioButton Content="Dark"  IsChecked="{Binding IsDarkTheme}"/>
                            <RadioButton Content="Light" IsChecked="{Binding IsDarkTheme,
                                                          Converter={x:Static BoolConverters.Not}}"/>
                        </StackPanel>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ── Swatches ──────────────────────────────────────────── -->
            <TextBlock Text="SWATCHES"
                       FontSize="10" FontWeight="SemiBold"
                       Opacity="0.4" LetterSpacing="1.5"
                       Margin="2,10,0,4"/>

            <Border BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6" Padding="12,10">
                <StackPanel Spacing="8">
                    <CheckBox Content="Show hex labels on swatches"
                              IsChecked="{Binding ShowHex}"/>
                    <CheckBox Content="Labels below swatches (default: on top)"
                              IsChecked="{Binding HexBelow}"
                              IsEnabled="{Binding ShowHex}"
                              Margin="0,0,0,0"/>
                </StackPanel>
            </Border>

            <!-- ── Metadata ──────────────────────────────────────────── -->
            <TextBlock Text="METADATA"
                       FontSize="10" FontWeight="SemiBold"
                       Opacity="0.4" LetterSpacing="1.5"
                       Margin="2,10,0,4"/>

            <Border BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6" Padding="12,10">
                <StackPanel Spacing="10">

                    <Grid ColumnDefinitions="110,*">
                        <TextBlock Text="Verbosity" VerticalAlignment="Center" Opacity="0.75"/>
                        <ComboBox Grid.Column="1" x:Name="MetaVerbosityBox"
                                  SelectedIndex="{Binding MetaVerbosityIndex}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>

                    <Grid ColumnDefinitions="110,*">
                        <TextBlock Text="Style" VerticalAlignment="Center" Opacity="0.75"/>
                        <ComboBox Grid.Column="1" x:Name="MetaStyleBox"
                                  SelectedIndex="{Binding MetaStyleIndex}"
                                  HorizontalAlignment="Stretch"/>
                    </Grid>

                </StackPanel>
            </Border>

            <!-- ── Output ────────────────────────────────────────── -->
            <TextBlock Text="OUTPUT"
                       FontSize="10" FontWeight="SemiBold"
                       Opacity="0.4" LetterSpacing="1.5"
                       Margin="2,10,0,4"/>

            <Border BorderBrush="#2A2A2A" BorderThickness="1" CornerRadius="6" Padding="12,10">
                <StackPanel Spacing="8">
                    <CheckBox Content="Show color palette (swatches)"
                              IsChecked="{Binding ShowSwatches}"/>
                    <CheckBox Content="Half size — compress 2× (~4× smaller file)"
                              IsChecked="{Binding HalfSize}"/>
                </StackPanel>
            </Border>

            <Button Content="OK"
                    HorizontalAlignment="Right"
                    Click="OnOkClick"
                    Margin="0,14,0,0"
                    Padding="24,6"/>

        </StackPanel>
    </ScrollViewer>

</Window>
